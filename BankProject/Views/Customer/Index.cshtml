@model List<BankProject.Models.Customer>

<h2>Müşteriler</h2>

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Ad Soyad</th>
            <th>Email</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var customer in Model)
        {
            <tr>
                <td>@customer.Id</td>
                <td>@customer.FullName</td>
                <td>@customer.Email</td>
            </tr>
        }
    </tbody>
</table>